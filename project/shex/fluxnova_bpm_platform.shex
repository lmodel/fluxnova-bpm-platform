PREFIX fluxnova_bpmn_model_fluxnova: <https://w3id.org/TD-Universe/fluxnova-bpmn-model/fluxnova_bpmn_model_fluxnova/>


linkml:String xsd:string

linkml:Integer xsd:integer

linkml:Boolean xsd:boolean

linkml:Float xsd:float

linkml:Double xsd:double

linkml:Decimal xsd:decimal

linkml:Time xsd:time

linkml:Date xsd:date

linkml:Datetime xsd:dateTime

linkml:DateOrDatetime linkml:DateOrDatetime

linkml:Uriorcurie IRI

linkml:Curie xsd:string

linkml:Uri IRI

linkml:Ncname xsd:string

linkml:Objectidentifier IRI

linkml:Nodeidentifier NONLITERAL

linkml:Jsonpointer xsd:string

linkml:Jsonpath xsd:string

linkml:Sparqlpath xsd:string

fluxnova_bpmn_model_instance:ActivationCondition CLOSED {
    (  $fluxnova_bpmn_model_instance:ActivationCondition_tes (  &fluxnova_bpmn_model_instance:Expression_tes ;
          rdf:type [ fluxnova_bpmn_model_instance:Expression ] ?
       ) ;
       rdf:type [ fluxnova_bpmn_model_instance:ActivationCondition ]
    )
}

fluxnova_bpmn_model_instance:Activity  (
    CLOSED {
       (  $fluxnova_bpmn_model_instance:Activity_tes (  &fluxnova_bpmn_model_instance:FlowNode_tes ;
             rdf:type [ fluxnova_bpmn_model_instance:FlowNode ] ? ;
             &fluxnova_bpmn_model_instance:InteractionNode_tes ;
             rdf:type [ fluxnova_bpmn_model_instance:InteractionNode ] ? ;
             fluxnova_bpmn_model_instance:for_compensation @linkml:Boolean ? ;
             fluxnova_bpmn_model_instance:start_quantity @linkml:Integer ? ;
             fluxnova_bpmn_model_instance:completion_quantity @linkml:Integer ? ;
             fluxnova_bpmn_model_instance:default @fluxnova_bpmn_model_instance:SequenceFlow ? ;
             fluxnova_bpmn_model_instance:io_specification @fluxnova_bpmn_model_instance:IoSpecification ? ;
             fluxnova_common:properties @fluxnova_bpmn_model_instance:BpmnProperty * ;
             fluxnova_bpmn_model_instance:data_input_associations @fluxnova_bpmn_model_instance:DataInputAssociation * ;
             fluxnova_bpmn_model_instance:data_output_associations @fluxnova_bpmn_model_instance:DataOutputAssociation * ;
             fluxnova_bpmn_model_instance:resource_roles @fluxnova_bpmn_model_instance:ResourceRole * ;
             fluxnova_bpmn_model_instance:loop_characteristics @fluxnova_bpmn_model_instance:LoopCharacteristics ?
          ) ;
          rdf:type [ fluxnova_bpmn_model_instance:Activity ]
       )
    } OR @fluxnova_bpmn_model_instance:BpmnTask OR @fluxnova_bpmn_model_instance:CallActivity OR
    @fluxnova_bpmn_model_instance:SubProcess
)

fluxnova_bpmn_model_instance:Artifact  (
    CLOSED {
       (  $fluxnova_bpmn_model_instance:Artifact_tes (  &fluxnova_bpmn_model_instance:BaseElement_tes ;
             rdf:type [ fluxnova_bpmn_model_instance:BaseElement ] ?
          ) ;
          rdf:type [ fluxnova_bpmn_model_instance:Artifact ]
       )
    } OR @fluxnova_bpmn_model_instance:Association OR @fluxnova_bpmn_model_instance:BpmnGroup OR
    @fluxnova_bpmn_model_instance:TextAnnotation
)

fluxnova_bpmn_model_instance:Assignment CLOSED {
    (  $fluxnova_bpmn_model_instance:Assignment_tes (  &fluxnova_bpmn_model_instance:BaseElement_tes ;
          rdf:type [ fluxnova_bpmn_model_instance:BaseElement ] ? ;
          fluxnova_bpmn_model_instance:from_ @linkml:String ? ;
          fluxnova_bpmn_model_instance:to_ @linkml:String ?
       ) ;
       rdf:type [ fluxnova_bpmn_model_instance:Assignment ]
    )
}

fluxnova_bpmn_model_instance:Association CLOSED {
    (  $fluxnova_bpmn_model_instance:Association_tes (  &fluxnova_bpmn_model_instance:Artifact_tes ;
          rdf:type [ fluxnova_bpmn_model_instance:Artifact ] ? ;
          fluxnova_common:source @fluxnova_bpmn_model_instance:BaseElement ? ;
          fluxnova_bpmn_model_instance:target @fluxnova_bpmn_model_instance:BaseElement ? ;
          fluxnova_bpmn_model_instance:association_direction @linkml:String ?
       ) ;
       rdf:type [ fluxnova_bpmn_model_instance:Association ]
    )
}

fluxnova_bpm_collaboration:Attachment CLOSED {
    (  $fluxnova_bpm_collaboration:Attachment_tes (  fluxnova_bpm_identity:user_id @linkml:String ? ;
          schema1:name @linkml:String ? ;
          schema1:description @linkml:String ? ;
          fluxnova_common:type @linkml:String ? ;
          fluxnova_bpm_runtime:task_id @linkml:String ? ;
          fluxnova_bpm_base:root_process_instance_id @linkml:String ? ;
          fluxnova_bpm_runtime:process_instance_id @linkml:String ? ;
          fluxnova_bpm_collaboration:url @linkml:String ? ;
          fluxnova_bpm_collaboration:content_id @linkml:String ? ;
          fluxnova_bpm_base:tenant_id @linkml:String ? ;
          fluxnova_bpm_base:create_time @linkml:Datetime ? ;
          fluxnova_bpm_base:removal_time @linkml:Datetime ?
       ) ;
       rdf:type [ fluxnova_bpm_collaboration:Attachment ]
    )
}

fluxnova_bpmn_model_instance:Auditing CLOSED {
    (  $fluxnova_bpmn_model_instance:Auditing_tes (  &fluxnova_bpmn_model_instance:BaseElement_tes ;
          rdf:type [ fluxnova_bpmn_model_instance:BaseElement ] ?
       ) ;
       rdf:type [ fluxnova_bpmn_model_instance:Auditing ]
    )
}

fluxnova_bpm_identity:Authorization CLOSED {
    (  $fluxnova_bpm_identity:Authorization_tes (  fluxnova_common:type [
             <https://w3id.org/TD-Universe/fluxnova-bpm-platform/AuthorizationType/0>
             <https://w3id.org/TD-Universe/fluxnova-bpm-platform/AuthorizationType/1>
             <https://w3id.org/TD-Universe/fluxnova-bpm-platform/AuthorizationType/2> ] ;
          fluxnova_bpm_identity:group_id @linkml:String ? ;
          fluxnova_bpm_identity:user_id @linkml:String ? ;
          fluxnova_bpm_identity:resource_type @linkml:Integer ;
          fluxnova_bpm_identity:resource_id @linkml:String ? ;
          fluxnova_bpm_identity:permissions @linkml:Integer ? ;
          fluxnova_bpm_base:removal_time @linkml:Datetime ? ;
          fluxnova_bpm_base:root_process_instance_id @linkml:String ?
       ) ;
       rdf:type [ fluxnova_bpm_identity:Authorization ]
    )
}

fluxnova_bpmn_model_instance:BaseElement  (
    CLOSED {
       (  $fluxnova_bpmn_model_instance:BaseElement_tes (  &fluxnova_bpmn_model_instance:BpmnModelElementInstance_tes ;
             rdf:type [ fluxnova_bpmn_model_instance:BpmnModelElementInstance ] ? ;
             fluxnova_bpmn_model_instance:documentations @fluxnova_bpmn_model_instance:Documentation * ;
             fluxnova_bpmn_model_instance:extension_elements @fluxnova_bpmn_model_instance:ExtensionElements ? ;
             fluxnova_bpmn_model_instance:diagram_element @fluxnova_bpmn_model_di:DiagramElement ?
          ) ;
          rdf:type [ fluxnova_bpmn_model_instance:BaseElement ]
       )
    } OR @fluxnova_bpmn_model_instance:Artifact OR @fluxnova_bpmn_model_instance:Assignment OR
    @fluxnova_bpmn_model_instance:Auditing OR @fluxnova_bpmn_model_instance:CategoryValue OR
    @fluxnova_bpmn_model_instance:ComplexBehaviorDefinition OR @fluxnova_bpmn_model_instance:ConversationAssociation OR
    @fluxnova_bpmn_model_instance:ConversationLink OR @fluxnova_bpmn_model_instance:ConversationNode OR
    @fluxnova_bpmn_model_instance:CorrelationKey OR @fluxnova_bpmn_model_instance:CorrelationPropertyBinding OR
    @fluxnova_bpmn_model_instance:CorrelationPropertyRetrievalExpression OR @fluxnova_bpmn_model_instance:CorrelationSubscription
    OR @fluxnova_bpmn_model_instance:DataAssociation OR @fluxnova_bpmn_model_instance:DataState OR
    @fluxnova_bpmn_model_instance:Expression OR @fluxnova_bpmn_model_instance:FlowElement OR @fluxnova_bpmn_model_instance:InputSet
    OR @fluxnova_bpmn_model_instance:IoBinding OR @fluxnova_bpmn_model_instance:IoSpecification OR
    @fluxnova_bpmn_model_instance:ItemAwareElement OR @fluxnova_bpmn_model_instance:Lane OR @fluxnova_bpmn_model_instance:LaneSet
    OR @fluxnova_bpmn_model_instance:LoopCharacteristics OR @fluxnova_bpmn_model_instance:MessageFlow OR
    @fluxnova_bpmn_model_instance:MessageFlowAssociation OR @fluxnova_bpmn_model_instance:Monitoring OR
    @fluxnova_bpmn_model_instance:Operation OR @fluxnova_bpmn_model_instance:OutputSet OR @fluxnova_bpmn_model_instance:Participant
    OR @fluxnova_bpmn_model_instance:ParticipantAssociation OR @fluxnova_bpmn_model_instance:ParticipantMultiplicity OR
    @fluxnova_bpmn_model_instance:Relationship OR @fluxnova_bpmn_model_instance:Rendering OR
    @fluxnova_bpmn_model_instance:ResourceAssignmentExpression OR @fluxnova_bpmn_model_instance:ResourceParameter OR
    @fluxnova_bpmn_model_instance:ResourceParameterBinding OR @fluxnova_bpmn_model_instance:ResourceRole OR
    @fluxnova_bpmn_model_instance:RootElement
)

fluxnova_bpm_job:Batch CLOSED {
    (  $fluxnova_bpm_job:Batch_tes (  fluxnova_common:type @linkml:String ? ;
          fluxnova_bpm_job:total_jobs @linkml:Integer ? ;
          fluxnova_bpm_job:jobs_created @linkml:Integer ? ;
          fluxnova_bpm_job:jobs_per_seed @linkml:Integer ? ;
          fluxnova_bpm_job:invocations_per_job @linkml:Integer ? ;
          fluxnova_bpm_job:seed_job_definition_id @linkml:String ? ;
          fluxnova_bpm_job:batch_job_definition_id @linkml:String ? ;
          fluxnova_bpm_job:monitor_job_definition_id @linkml:String ? ;
          fluxnova_bpm_repository:suspension_state [ <https://w3id.org/TD-Universe/fluxnova-bpm-platform/SuspensionState/1>
             <https://w3id.org/TD-Universe/fluxnova-bpm-platform/SuspensionState/2> ] ? ;
          fluxnova_bpm_runtime:configuration @linkml:String ? ;
          fluxnova_bpm_base:tenant_id @linkml:String ? ;
          fluxnova_bpm_job:create_user_id @linkml:String ? ;
          fluxnova_bpm_job:start_time @linkml:Datetime ? ;
          fluxnova_bpm_job:execution_start_time @linkml:Datetime ?
       ) ;
       rdf:type [ fluxnova_bpm_job:Batch ]
    )
}

fluxnova_bpmn_model_instance:BoundaryEvent CLOSED {
