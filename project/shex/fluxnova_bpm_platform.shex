    CLOSED {
       (  $fluxnova_bpmn_model_instance:BpmnModelElementInstance_tes fluxnova_bpmn_model_instance:scope
          @fluxnova_bpmn_model_instance:BpmnModelElementInstance ? ;
          rdf:type [ fluxnova_bpmn_model_instance:BpmnModelElementInstance ] ?
       )
    } OR @fluxnova_bpmn_model_instance:BaseElement OR @fluxnova_bpmn_model_dc:Bounds OR @fluxnova_bpmn_model_instance:Definitions
