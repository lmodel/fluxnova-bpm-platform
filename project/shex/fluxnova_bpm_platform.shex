fluxnova_bpmn_model_instance:BpmnTask  (
    CLOSED {
       (  $fluxnova_bpmn_model_instance:BpmnTask_tes (  &fluxnova_bpmn_model_instance:Activity_tes ;
             rdf:type [ fluxnova_bpmn_model_instance:Activity ] ? ;
