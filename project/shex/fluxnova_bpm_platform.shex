    @fluxnova_bpmn_model_fluxnova:FluxnovaFormData OR @fluxnova_bpmn_model_fluxnova:FluxnovaFormField OR
    @fluxnova_bpmn_model_fluxnova:FluxnovaFormProperty OR @fluxnova_bpmn_model_fluxnova:FluxnovaIn OR
    @fluxnova_bpmn_model_fluxnova:FluxnovaInputOutput OR @fluxnova_bpmn_model_fluxnova:FluxnovaInputParameter OR
    @fluxnova_bpmn_model_fluxnova:FluxnovaList OR @fluxnova_bpmn_model_fluxnova:FluxnovaMap OR
    @fluxnova_bpmn_model_fluxnova:FluxnovaOut OR @fluxnova_bpmn_model_fluxnova:FluxnovaOutputParameter OR
    @fluxnova_bpmn_model_fluxnova:FluxnovaPotentialStarter OR @fluxnova_bpmn_model_fluxnova:FluxnovaProperties OR
    @fluxnova_bpmn_model_fluxnova:FluxnovaProperty OR @fluxnova_bpmn_model_fluxnova:FluxnovaScript OR
    @fluxnova_bpmn_model_fluxnova:FluxnovaString OR @fluxnova_bpmn_model_fluxnova:FluxnovaTaskListener OR
