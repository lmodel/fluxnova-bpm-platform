<https://w3id.org/lmodel/fluxnova-bpm-platform/history/HistoricActivityInstance> a sh:NodeShape ;
    rdfs:comment "Represents one execution of an activity and it's stored permanent for statistics, audit and other business intelligence purposes." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Reference to the execution." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/runtime/execution_id> ],
        [ sh:datatype xsd:string ;
            sh:description "The display name for the activity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/history/activity_name> ],
        [ sh:datatype xsd:string ;
            sh:description "Reference to the process definition." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/runtime/process_definition_id> ],
        [ sh:datatype xsd:string ;
            sh:description "Id of the parent activity instance" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/history/parent_activity_instance_id> ],
        [ sh:datatype xsd:string ;
            sh:description "The activity type of the activity. Typically the activity type correspond to the XML tag used in the BPMN 2.0 process definition file. All activity types are available in org.finos.fluxnova.bpm.eng..." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/history/activity_type> ],
        [ sh:datatype xsd:string ;
            sh:description "The called case instance in case of (case) call activity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/history/called_case_instance_id> ],
        [ sh:datatype xsd:integer ;
            sh:description "Monotonically increasing counter for ordering." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/runtime/sequence_counter> ],
        [ sh:datatype xsd:string ;
            sh:description "BPMN activity element identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/runtime/activity_id> ],
        [ sh:datatype xsd:string ;
            sh:description "Multi-tenancy discriminator." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/tenant_id> ],
        [ sh:datatype xsd:dateTime ;
            sh:description "End timestamp." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/history/end_time> ],
        [ sh:description "The activity instance state." ;
            sh:in ( <https://w3id.org/lmodel/fluxnova-bpm-platform/ActivityInstanceState/0> <https://w3id.org/lmodel/fluxnova-bpm-platform/ActivityInstanceState/1> <https://w3id.org/lmodel/fluxnova-bpm-platform/ActivityInstanceState/2> <https://w3id.org/lmodel/fluxnova-bpm-platform/ActivityInstanceState/3> <https://w3id.org/lmodel/fluxnova-bpm-platform/ActivityInstanceState/4> ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/history/activity_instance_state> ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when this entity is eligible for removal." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/removal_time> ],
        [ sh:datatype xsd:integer ;
            sh:description "Duration in milliseconds." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/history/duration> ],
        [ sh:datatype xsd:string ;
            sh:description "Key of the process definition." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/runtime/process_definition_key> ],
        [ sh:datatype xsd:string ;
            sh:description "Reference to the task." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
