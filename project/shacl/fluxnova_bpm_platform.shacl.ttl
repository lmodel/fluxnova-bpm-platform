<https://w3id.org/lmodel/fluxnova-bpm-platform/collaboration/Attachment> a sh:NodeShape ;
    rdfs:comment "Any type of content that is be associated with a task or with a process instance." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path schema1:name ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when this entity is eligible for removal." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/removal_time> ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Reference to a user." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/identity/user_id> ],
        [ sh:datatype xsd:string ;
            sh:description "The remote URL in case this is remote content. If the attachment content was uploaded with an input stream, then this method returns null and the content can be fetched with ." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/collaboration/url> ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path schema1:description ],
        [ sh:datatype xsd:string ;
            sh:description "Reference to the task." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/runtime/task_id> ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/create_time> ],
        [ sh:datatype xsd:string ;
            sh:description "Multi-tenancy discriminator." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/tenant_id> ],
        [ sh:datatype xsd:string ;
            sh:description "Root process instance for history cleanup." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/root_process_instance_id> ],
        [ sh:datatype xsd:string ;
            sh:description "Type discriminator." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/fluxnova_common/type> ],
        [ sh:datatype xsd:string ;
            sh:description "Reference to the content." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/collaboration/content_id> ],
        [ sh:datatype xsd:string ;
            sh:description "Reference to the process instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/runtime/process_instance_id> ] ;
    sh:targetClass <https://w3id.org/lmodel/fluxnova-bpm-platform/collaboration/Attachment> .

<https://w3id.org/lmodel/fluxnova-bpm-platform/collaboration/Comment> a sh:NodeShape ;
    rdfs:comment "User comments that form discussions around tasks." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Short message or summary." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/fluxnova_common/message> ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Multi-tenancy discriminator." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/tenant_id> ],
        [ sh:datatype xsd:string ;
            sh:description "The full comment message the user had related to the task and/or process instance" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/collaboration/full_message> ],
        [ sh:datatype xsd:string ;
            sh:description "Reference to the task." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/runtime/task_id> ],
        [ sh:datatype xsd:string ;
