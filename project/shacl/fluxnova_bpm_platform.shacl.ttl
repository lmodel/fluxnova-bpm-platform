    sh:targetClass <https://w3id.org/lmodel/fluxnova-bpm-platform/base/Property> .

<https://w3id.org/lmodel/fluxnova-bpm-platform/base/SchemaLogEntry> a sh:NodeShape ;
    rdfs:comment "Schema Log Entry entity in the engine infrastructure." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
