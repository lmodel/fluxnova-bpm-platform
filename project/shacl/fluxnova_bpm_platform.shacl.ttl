            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/runtime/process_definition_id> ],
        [ sh:description "Current state of HistoricProcessInstance, following values are recognized during process engine operations: STATE_ACTIVE - running process instance STATE_SUSPENDED - suspended process instances STA..." ;
            sh:in ( "ACTIVE" "SUSPENDED" "COMPLETED" "EXTERNALLY_TERMINATED" "INTERNALLY_TERMINATED" ) ;
