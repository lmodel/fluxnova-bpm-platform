            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/identity/user_id> ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when this entity is eligible for removal." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/removal_time> ],
        [ sh:datatype xsd:string ;
            sh:description "The action." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/collaboration/action> ],
        [ sh:datatype xsd:string ;
            sh:description "Reference to the process instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/runtime/process_instance_id> ] ;
    sh:targetClass <https://w3id.org/lmodel/fluxnova-bpm-platform/collaboration/Comment> .

<https://w3id.org/lmodel/fluxnova-bpm-platform/collaboration/Filter> a sh:NodeShape ;
    rdfs:comment "Filter entity in the user collaboration." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path schema1:name ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
