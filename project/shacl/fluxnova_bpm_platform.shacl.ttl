@prefix fluxnova_bpm_platform: <https://w3id.org/lmodel/fluxnova-bpm-platform/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

fluxnova_bpm_platform:FluxnovaPlatformData a sh:NodeShape ;
    rdfs:comment "Root container for Fluxnova BPM Platform data." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/fluxnova-bpm-platform/runtime/Execution> ;
            sh:description "Process execution instances." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path fluxnova_bpm_platform:executions ],
        [ sh:class <https://w3id.org/lmodel/fluxnova-bpm-platform/identity/Group> ;
            sh:description "Identity groups." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path fluxnova_bpm_platform:groups ],
        [ sh:class <https://w3id.org/lmodel/fluxnova-bpm-platform/runtime/Task> ;
            sh:description "User tasks." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path fluxnova_bpm_platform:tasks ],
        [ sh:class <https://w3id.org/lmodel/fluxnova-bpm-platform/job/Job> ;
            sh:description "Asynchronous jobs." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path fluxnova_bpm_platform:jobs ],
        [ sh:class <https://w3id.org/lmodel/fluxnova-bpm-platform/job/Batch> ;
            sh:description "Batch operations." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path fluxnova_bpm_platform:batches ],
        [ sh:class <https://w3id.org/lmodel/fluxnova-bpm-platform/repository/Deployment> ;
            sh:description "Deployed resources." ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path fluxnova_bpm_platform:deployments ],
        [ sh:class <https://w3id.org/lmodel/fluxnova-bpm-platform/identity/User> ;
            sh:description "Identity users." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path fluxnova_bpm_platform:users ],
        [ sh:class <https://w3id.org/lmodel/fluxnova-bpm-platform/repository/ProcessDefinition> ;
            sh:description "Process definitions." ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path fluxnova_bpm_platform:process_definitions ] ;
    sh:targetClass fluxnova_bpm_platform:FluxnovaPlatformData .

<https://w3id.org/lmodel/fluxnova-bpm-platform/base/ByteArray> a sh:NodeShape ;
    rdfs:comment "Byte Array entity in the engine infrastructure." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Root process instance for history cleanup." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/root_process_instance_id> ],
        [ sh:datatype xsd:string ;
            sh:description "Multi-tenancy discriminator." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/tenant_id> ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when this entity is eligible for removal." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/removal_time> ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path schema1:name ],
        [ sh:datatype xsd:string ;
            sh:description "Reference to the deployment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/deployment_id> ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/create_time> ],
        [ sh:datatype xsd:integer ;
            sh:description "Type discriminator." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/fluxnova_common/type> ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether this entity is generated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/is_generated> ],
        [ sh:datatype xsd:string ;
            sh:description "Serialized binary content." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/bytes> ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path schema1:identifier ] ;
    sh:targetClass <https://w3id.org/lmodel/fluxnova-bpm-platform/base/ByteArray> .

<https://w3id.org/lmodel/fluxnova-bpm-platform/base/MeterLog> a sh:NodeShape ;
    rdfs:comment "Meter Log entity in the engine infrastructure." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Identifier of the reporting node." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/reporter> ],
        [ sh:datatype xsd:integer ;
            sh:description "The milliseconds." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/milliseconds> ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Time when this log occurred." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/base/timestamp> ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:integer ;
            sh:description "Value of this variable instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fluxnova-bpm-platform/fluxnova_common/value> ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path schema1:name ] ;
    sh:targetClass <https://w3id.org/lmodel/fluxnova-bpm-platform/base/MeterLog> .

<https://w3id.org/lmodel/fluxnova-bpm-platform/base/Property> a sh:NodeShape ;
    rdfs:comment "Property entity in the engine infrastructure." ;
